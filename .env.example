# Optional — override the local Ollama models. No API key anywhere: everything runs on
# local models, nothing is sent to the cloud.
# The chat model (doc extraction residuals, Ask-the-doc answers, the plan assistant, /parse):
# OLLAMA_MODEL=granite4.1:8b
# The embedding model (Ask-the-doc retrieval; pull it once: `ollama pull nomic-embed-text`):
# OLLAMA_EMBED_MODEL=nomic-embed-text
