{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pip install -r requirements.txt)",
      "Bash(pip install *)",
      "Bash(flask --app app run *)",
      "Bash(python -c *)",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(./.venv/Scripts/python.exe *)",
      "Bash(.venv/Scripts/python.exe *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch --list *)",
      "Bash(git remote -v)",
      "Bash(git stash list)",

      "PowerShell(pip install -r requirements.txt)",
      "PowerShell(pip install *)",
      "PowerShell(flask --app app run *)",
      "PowerShell(python -c *)",
      "PowerShell(python -m pytest *)",
      "PowerShell(pytest *)",
      "PowerShell(.\\.venv\\Scripts\\python.exe *)",
      "PowerShell(git status *)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)",
      "PowerShell(git show *)",
      "PowerShell(git branch)",
      "PowerShell(git branch --list *)",
      "PowerShell(git remote -v)",
      "PowerShell(git stash list)",

      "Read(/app.py)",
      "Read(/models.py)",
      "Read(/parse.py)",
      "Read(/solver.py)",
      "Read(/requirements.txt)",
      "Read(/README.md)",
      "Read(/ARCHITECTURE.md)",
      "Read(/CLAUDE.md)",
      "Read(/.env.example)",
      "Read(/templates/**)",
      "Read(/static/**)",

      "Edit(/app.py)",
      "Edit(/models.py)",
      "Edit(/parse.py)",
      "Edit(/solver.py)",
      "Edit(/requirements.txt)",
      "Edit(/README.md)",
      "Edit(/ARCHITECTURE.md)",
      "Edit(/templates/**)",
      "Edit(/static/**)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git revert *)",
      "Bash(git checkout *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(git revert *)",
      "PowerShell(git checkout *)",
      "PowerShell(git reset *)",
      "PowerShell(git restore *)",
      "PowerShell(git clean *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "PowerShell(git push --force *)",
      "PowerShell(git push -f *)",
      "PowerShell(git reset --hard *)",
      "Read(.env)",
      "Edit(.env)"
    ]
  }
}
